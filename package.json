{
  "name": "pew.md",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run src/__tests__/e2e",
    "test:e2e:bdd": "bunx playwright test",
    "check": "bun run lint && bun run test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "next": "16.2.11",
    "postcss": "^8.5.21",
    "react": "^19.2.8",
    "react-dom": "^19.2.7"
  },
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.11",
    "husky": "^9.1.7",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "minimatch@3>brace-expansion": "^1.1.16",
    "minimatch@10>brace-expansion": "^5.0.7",
    "@babel/core": "^7.29.7",
    "js-yaml": "^4.2.0",
    "vite": "^8.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  }
}
